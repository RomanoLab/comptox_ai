# Copy to .env to override defaults locally. The API also picks values up
# from the process environment, so a top-level .env file works too.

# Database connection (Bolt protocol).
# Default: bolt://localhost:7687  (Memgraph's canonical Bolt port)
# Inside docker compose, this is set to bolt://memgraph:7687.
COMPTOX_AI_DATABASE_URL=bolt://localhost:7687

# Memgraph Community has no auth; leave blank.
COMPTOX_AI_DATABASE_USER=
COMPTOX_AI_DATABASE_PASSWORD=

# API server port.
PORT=3001

# Node environment. Use "development" locally for verbose logging; "production"
# in containers.
NODE_ENV=development

# Public URL displayed in Swagger UI.
API_PUBLIC_URL=http://localhost:3001
